# Deploy-time configuration. Copy to .env (gitignored) and fill in.
# Never commit real secrets — LinkedIn tokens & API keys live in AWS Secrets Manager.

AWS_REGION=us-east-1

# Bedrock model ids you have enabled (Bedrock console → Model access).
# Prefer the latest Claude inference profile for text.
BEDROCK_TEXT_MODEL=anthropic.claude-3-5-sonnet-20241022-v2:0
BEDROCK_IMAGE_MODEL=amazon.titan-image-generator-v2:0

# Admin web (set to the deployed HttpApi URL from the CDK output)
VITE_API_URL=
